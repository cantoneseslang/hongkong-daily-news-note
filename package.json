{
  "name": "hongkong-daily-news-note",
  "version": "1.0.0",
  "type": "module",
  "description": "香港ニュース自動生成・投稿システム",
  "main": "post_to_note_playwright.js",
  "scripts": {
    "post": "node post_to_note_github_actions.js",
    "note:auth": "node scripts/note_save_auth_state.js",
    "note:auth:storage": "playwright open https://editor.note.com/new --channel=chrome --save-storage=.note-auth-state.json",
    "note:auth:cdp": "node scripts/note_save_auth_state_cdp.js",
    "note:cookie": "node scripts/export_note_session_cookie.js",
    "note:cookie:cdp": "node scripts/export_note_session_cookie_cdp.js"
  },
  "keywords": [
    "hongkong",
    "news",
    "automation",
    "note.com"
  ],
  "author": "cantoneseslang",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "marked": "^15.0.0",
    "playwright": "^1.40.0"
  }
}
